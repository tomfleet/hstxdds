void apply_dds_config(uint32_t freq_hz, uint8_t *buf, uint32_t len) {
    uint32_t sys_clk = clock_get_hz(clk_sys);
    
    // The HSTX CLKDIV is a 12-bit field within the CSR register.
    // Usually treated as an integer divider where 0 or 1 = clk_sys speed.
    uint32_t div = sys_clk / freq_hz;
    if (div > 0xFFF) div = 0xFFF; // Cap at 12 bits

    // Construct the CSR value
    // Bits 27:16 = CLKDIV
    // Bits 15:12 = SHIFT (8 bits for your binary format)
    // Bit 0 = EN (Enable)
    uint32_t csr_val = (div << HSTX_CTRL_CSR_CLKDIV_LSB) |
                       (8 << HSTX_CTRL_CSR_SHIFT_LSB) |
                       HSTX_CTRL_CSR_EN_BITS;

    // Apply to hardware
    hstx_ctrl_hw->csr = csr_val;

    // Route shifter to output pins 0-7
    for (int i = 0; i < 8; i++) {
        hstx_ctrl_hw->bit[i] = 0; // 0 is the 'raw' shifter source
    }

    // DMA Setup
    if (dds_dma_chan < 0) {
        dds_dma_chan = dma_claim_unused_channel(true);
    } else {
        dma_channel_abort(dds_dma_chan);
    }

    dma_channel_config c = dma_channel_get_default_config(dds_dma_chan);
    channel_config_set_transfer_data_size(&c, DMA_SIZE_8);
    channel_config_set_read_increment(&c, true);
    channel_config_set_write_increment(&c, false);
    channel_config_set_dreq(&c, DREQ_HSTX);

    dma_channel_configure(
        dds_dma_chan,
        &c,
        (void *)&hstx_fifo_hw->fifo,
        buf,
        len,
        true
    );
}

void dds_init(uint gpio_pin) {
    // Set parallel output pins to HSTX
    for (int i = 0; i < 8; i++) {
        gpio_set_function(i, GPIO_FUNC_HSTX);
    }

    // PWM setup (kept as requested for pin)
    gpio_set_function(gpio_pin, GPIO_FUNC_PWM);
    dds_slice = pwm_gpio_to_slice_num(gpio_pin);
    pwm_config cfg = pwm_get_default_config();
    pwm_config_set_wrap(&cfg, 255);
    pwm_init(dds_slice, &cfg, true);

    // Claim and configure the DMA channel for HSTX
    if (dds_dma_chan < 0) {
        dds_dma_chan = dma_claim_unused_channel(true);
    }
    
    dma_channel_config c = dma_channel_get_default_config(dds_dma_chan);
    channel_config_set_transfer_data_size(&c, DMA_SIZE_8);
    channel_config_set_read_increment(&c, true);
    channel_config_set_write_increment(&c, false);
    channel_config_set_dreq(&c, DREQ_HSTX); 
    
    dma_channel_set_config(dds_dma_chan, &c, false);
}

void process_mailbox() {
    switch (current_state) {
        case DDS_STATE_IDLE:
            if (SEGGER_RTT_HasData(0)) {
                uint8_t c;
                SEGGER_RTT_Read(0, &c, 1);
                if (c == 0xEF) {
                    header_buffer[0] = 0xEF;
                    current_state = DDS_STATE_READ_HEADER;
                } else if (c == '1') { gpio_put(25, 1); }
                  else if (c == '0') { gpio_put(25, 0); }
                  else if (c == 'r') {
                                    // Optional: Log what we are doing to Channel 0
                                    SEGGER_RTT_printf(0, "Sending %u bytes from 0x%p to Chan 1...\n", 
                                                    current_config.buffer_len, 
                                                    current_config.waveform_buffer);
                                                    
                                    // Write the actual binary data to Channel 1
                                    SEGGER_RTT_Write(1, current_config.waveform_buffer, current_config.buffer_len);
                                }
            }
            break;

        case DDS_STATE_READ_HEADER:
            if (SEGGER_RTT_GetBytesInBuffer(0) >= 19) {
                SEGGER_RTT_Read(0, &header_buffer[1], 19);
                memcpy(&incoming_header, header_buffer, 20);
                if (incoming_header.sync == 0xDEADBEEF) {
                    current_state = DDS_STATE_READ_DATA;
                } else {
                    current_state = DDS_STATE_IDLE;
                }
            }
            break;

        case DDS_STATE_READ_DATA:
            if (SEGGER_RTT_GetBytesInBuffer(1) >= incoming_header.len) {
                uint32_t r = SEGGER_RTT_Read(1, wavetable_ram, incoming_header.len);
                current_config.buffer_len = r;
                apply_dds_config(incoming_header.fstart, wavetable_ram, r);
                SEGGER_RTT_printf(0, "DDS Sync: %u bytes @ %u Hz\n", r, incoming_header.fstart);
                current_state = DDS_STATE_IDLE;
            }
            break;
    }
}


void dds_update_config(dds_config_t *config) {
    if (config->buffer_len == 0) return;
    
    // Trigger HSTX via your apply_dds_config function
    apply_dds_config(config->fstart, config->waveform_buffer, config->buffer_len);
    
    SEGGER_RTT_WriteString(0, "DDS Config Applied.\n");
}


void dds_update_config2(dds_config_t *new_cfg) {
    // 1. Safety check for the binary payload
    if (!new_cfg->waveform_buffer || new_cfg->buffer_len == 0) {
        SEGGER_RTT_WriteString(0, "Error: Empty Waveform Buffer\n");
        return;
    }

    // 2. Trigger the HSTX hardware configuration
    apply_dds_config(new_cfg->fstart, new_cfg->waveform_buffer, new_cfg->buffer_len);

    // 3. Correct Formatted API: SEGGER_RTT_printf (lowercase 'p')
    // This confirms the mailbox actually received the frequency values
    SEGGER_RTT_printf(0, "DDS Config Applied: %u Hz -> %u Hz (%u bytes)\n", 
                      new_cfg->fstart, 
                      new_cfg->fend, 
                      new_cfg->buffer_len);
}